{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "next.config.ts",
    "postcss.config.mjs",
    "vitest.config.ts",
    "vitest.setup.ts",
    "app/**/{page,layout,loading,error,not-found,route}.tsx",
    "app/**/route.ts",
    "middleware.ts",
    "instrumentation.ts",
    "capacitor.config.ts",
    "electron/main.cjs",
    "electron/preload.cjs",
    "scripts/**/*.cjs",
    "scripts/**/*.mjs"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "contexts/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "tests/**/*.{ts,tsx}",
    "electron/**/*.{cjs,mjs,js,ts}",
    "capacitor.config.ts",
    "*.config.{ts,mjs,cjs}",
    "*.setup.ts"
  ],
  "ignore": [
    ".opencode/**",
    ".tools/**",
    ".venv/**",
    "android/app/build/**",
    "android/app/src/main/assets/public/**",
    "ios/App/App/public/**",
    "capacitor-web/**",
    "coverage/**",
    "playwright-report/**",
    "public/sw.js",
    "public/notification-worker.js",
    "tests/mocks/**",
    "tests/shims/**",
    "scripts/gen-tests.cjs",
    "scripts/migrate-content.mjs",
    "scripts/run-new-tests.cjs",
    "lib/mobile/**",
    "lib/types/**",
    "electron-builder.config.cjs",
    "electron/preload.cjs",
    "components/auth/auth-mode-switch.tsx",
    "components/auth/country-code-select.tsx",
    "components/auth/register/register-step-progress.tsx",
    "components/domain/OetStatementOfResultsCard.tsx",
    "components/domain/pronunciation/**",
    "components/domain/rulebook-findings-panel.tsx",
    "components/domain/strategies/admin-strategy-guide-editor.tsx",
    "components/domain/vocabulary/**",
    "components/layout/**",
    "components/ui/**",
    "electron/**",
    "hooks/**",
    "lib/**",
    "tests/**"
  ],
  "ignoreDependencies": [
    "@aparajita/capacitor-biometric-auth",
    "@capacitor/camera",
    "@capacitor/device",
    "@capacitor/filesystem",
    "@electron/fuses",
    "@google/genai",
    "@next/env",
    "@revenuecat/purchases-capacitor",
    "@tailwindcss/typography",
    "@tanstack/react-query-devtools",
    "capacitor-voice-recorder",
    "class-variance-authority",
    "electron-builder",
    "postcss-load-config",
    "tailwindcss",
    "tw-animate-css"
  ],
  "ignoreBinaries": [
    "dotnet"
  ],
  "ignoreExportsUsedInFile": true
}
