{
  "name": "oet-with-dr-hesham",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "description": "OET with Dr Hesham desktop shell",
  "author": "OET with Dr Hesham",
  "scripts": {
    "dev": "next dev",
    "mobile:dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "mobile:build": "pnpm run build && cap sync",
    "mobile:sync": "cap sync",
    "mobile:copy": "cap copy",
    "mobile:run:android": "cap run android",
    "mobile:run:ios": "cap run ios",
    "mobile:open:android": "cap open android",
    "mobile:open:ios": "cap open ios",
    "desktop:dev": "node ./scripts/tauri-dev.cjs",
    "desktop:dist": "node ./scripts/tauri-dist.cjs build",
    "lint": "eslint app components contexts hooks lib next.config.ts postcss.config.mjs vitest.config.ts vitest.setup.ts eslint.config.mjs",
    "check:encoding": "node ./scripts/check-mojibake.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:install": "playwright install chromium firefox webkit",
    "test:e2e:auth": "node ./scripts/qa/assert-local-stack.mjs && playwright test tests/e2e/setup/auth.setup.ts",
    "test:e2e": "node ./scripts/qa/run-playwright-matrix.mjs full",
    "test:e2e:smoke": "node ./scripts/qa/run-playwright-matrix.mjs smoke",
    "test:e2e:a11y": "node ./scripts/qa/assert-local-stack.mjs && playwright test tests/e2e/shared/accessibility.spec.ts",
    "test:e2e:prod-privileged": "playwright test -c playwright.prod-privileged.config.ts",
    "test:e2e:headed": "node ./scripts/qa/assert-local-stack.mjs && playwright test --headed",
    "test:e2e:report": "playwright show-report output/playwright/report",
    "clean": "next clean",
    "backend:run": "dotnet run --project backend/src/OetWithDrHesham.Api/OetWithDrHesham.Api.csproj",
    "backend:test": "dotnet test backend/OetWithDrHesham.sln",
    "backend:build": "dotnet build backend/OetWithDrHesham.sln",
    "backend:watch": "dotnet watch --project backend/src/OetWithDrHesham.Api/OetWithDrHesham.Api.csproj run",
    "backend:smoke": "dotnet run --no-build --project backend/src/OetWithDrHesham.Api/OetWithDrHesham.Api.csproj",
    "docker:local:up": "docker compose -f docker-compose.local.yml --env-file .env.docker-local up --build -d",
    "docker:local:down": "docker compose -f docker-compose.local.yml --env-file .env.docker-local down",
    "docker:local:logs": "docker compose -f docker-compose.local.yml --env-file .env.docker-local logs -f",
    "docker:local:ps": "docker compose -f docker-compose.local.yml --env-file .env.docker-local ps",
    "docker:dev:up": "docker compose -f docker-compose.dev.yml --env-file .env.docker-local up --build -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml --env-file .env.docker-local down",
    "docker:test": "docker run --rm -v .:/src:ro -v oet_web_node_modules_node22:/src/node_modules -w /src node:22-alpine sh -c \"corepack enable && pnpm test\"",
    "docker:test:backend": "docker exec oet-local-api dotnet test /app/OetWithDrHesham.sln",
    "docker:lint": "docker run --rm -v .:/src:ro -v oet_web_node_modules_node22:/src/node_modules -w /src node:22-alpine sh -c \"corepack enable && pnpm run lint\"",
    "docker:tsc": "docker run --rm -v .:/src:ro -v oet_web_node_modules_node22:/src/node_modules -w /src node:22-alpine sh -c \"corepack enable && pnpm exec tsc --noEmit\"",
    "docker:tsc:setup": "docker volume create oet_web_node_modules_node22 && docker run --rm -v .:/src:ro -v oet_web_node_modules_node22:/src/node_modules -w /src node:22-alpine sh -c \"corepack enable && pnpm install --frozen-lockfile --ignore-scripts\"",
    "docker:build:check": "docker compose -f docker-compose.local.yml --env-file .env.docker-local build",
    "ai:gateway:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/test-cf-gateway.ps1",
    "ai:workers:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/test-cf-workers-ai.ps1",
    "qa:a11y:signoff-template": "node ./scripts/qa/create-accessibility-signoff-template.mjs",
    "qa:a11y:signoff:validate": "node ./scripts/qa/validate-accessibility-signoff.mjs",
    "unused:scan": "ts-prune -p tsconfig.json | node ./scripts/ts-prune-filter.mjs",
    "repomix:pack": "npx -y repomix@latest",
    "repomix:pack:compress": "npx -y repomix@latest --compress",
    "repomix:hook:install": "powershell -ExecutionPolicy Bypass -File ./scripts/repomix/install-hook.ps1"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^7.2.0",
