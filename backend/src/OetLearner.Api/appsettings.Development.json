{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=oet_learner_dev.db"
  },
  "Auth": {
    "UseDevelopmentAuth": true
  },
  "AuthTokens": {
    "Issuer": "https://api.local.oetlearner.test",
    "Audience": "oet-learner-web",
    "AccessTokenSigningKey": "dev-access-token-signing-key-1234567890",
    "RefreshTokenSigningKey": "dev-refresh-token-signing-key-1234567890",
    "AccessTokenLifetime": "00:15:00",
    "RefreshTokenLifetime": "30.00:00:00",
    "OtpLifetime": "00:10:00",
    "AuthenticatorIssuer": "OET Learner (Dev)"
  },
  "Bootstrap": {
    "AutoMigrate": true,
    "SeedDemoData": true
  },
  "Platform": {
    "PublicApiBaseUrl": "http://localhost:5198",
    "PublicWebBaseUrl": "http://localhost:3000",
    "FallbackEmailDomain": "example.test"
  },
  "ExternalAuth": {
    "Google": {
      "Enabled": false,
      "ClientId": "",
      "ClientSecret": ""
    },
    "Facebook": {
      "Enabled": false,
      "ClientId": "",
      "ClientSecret": ""
    },
    "LinkedIn": {
      "Enabled": false,
      "ClientId": "",
      "ClientSecret": ""
    }
  },
  "Billing": {
    "CheckoutBaseUrl": "http://localhost:3000/billing/checkout"
  },
  "Proxy": {
    "TrustForwardHeaders": false,
    "EnforceHttps": false
  },
  "Features": {
    "EnableSwagger": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
