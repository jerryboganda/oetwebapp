# Repomix-specific ignores (applied on top of .gitignore)
# Goal: keep the AI bundle focused on source code + canonical docs/specs,
# strip large generated/vendor/binary artifacts that hurt token budget.

# Lock files (huge, regenerable, low semantic value)
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb
backend/**/packages.lock.json

# Mobile platform scaffolds (regenerated by Capacitor)
android/
ios/
$sdkRoot/

# Capacitor web shim (generated)
capacitor-web/

# Built/generated frontend
.next/
out/
desktop-backend-runtime/

# .NET build outputs
backend/**/bin/
backend/**/obj/
**/bin/
**/obj/

# Test artifacts and reports
playwright-report*/
playwright/.auth/
test-results/
coverage/
output/

# Local content drops / vendor blobs that .gitignore already excludes
# (defensive — ignored even if someone un-ignores them)
Project Real Content/
_extracted/
_previous_chat_history/

# Environment + local-only files
.env*
!.env.example
!.env.staging.example

# IDE / agent caches
.claude/
.agents/
.cursor/
.kilo/
.opencode/
.commandcode/
.sisyphus/
.tools/

# Repomix's own outputs (do not pack a previous bundle into the new one)
repomix-output.*

# Generated DBs and large local fixtures
backend/oet_learner_dev.sqlite
backend/src/OetLearner.Api/Data/Migrations/__PendingProbe/

# Public binary assets (kept out of token budget — paths still listed)
public/**/*.{png,jpg,jpeg,gif,webp,ico,svg,mp4,mp3,wav,ogg,pdf,zip,woff,woff2,ttf,otf,eot}

# Build/bench/log scratch files
build-*.txt
server*.log
dev*.log
dev-output.txt
tsconfig.tsbuildinfo
*_out.txt
*_out2.txt
*_output.txt
vitest_*.json
vitest_*.txt
vitest_output*
audit-*.png
audit-*.md
audit-*.snapshot.md
test-full.log
front-test.log

# MemPalace per-project state
mempalace.yaml
entities.json
.mempalace/
