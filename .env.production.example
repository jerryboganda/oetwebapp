# Frontend public URLs
APP_URL=https://app.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
PUBLIC_API_BASE_URL=https://api.example.com
CHECKOUT_BASE_URL=https://app.example.com/billing/checkout
CORS_ALLOWED_ORIGINS=https://app.example.com

# Shared Docker network used by Nginx Proxy Manager
NPM_PROXY_NETWORK=npm_proxy
HOST_WEB_PORT=3003
HOST_API_PORT=5001

# Next.js server-side integrations
GEMINI_API_KEY=replace-me
NEXT_PUBLIC_ENABLE_MOCK_AUTH=false

# PostgreSQL
POSTGRES_DB=oet_learner
POSTGRES_USER=oet_learner
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# JWT validation: set AUTH_AUTHORITY for an external identity provider,
# or leave it blank and provide Issuer/Audience/SigningKey for symmetric validation.
AUTH_AUTHORITY=
AUTH_AUDIENCE=oet-learner-api
AUTH_ISSUER=https://auth.example.com
AUTH_SIGNING_KEY=replace-with-at-least-32-characters-of-random-secret
AUTH_REQUIRE_HTTPS_METADATA=true

# Bootstrap expert account for the built-in .NET auth flow
BOOTSTRAP_EXPERT_EMAIL=expert@example.com
BOOTSTRAP_EXPERT_PASSWORD=replace-with-a-strong-expert-password
BOOTSTRAP_EXPERT_DISPLAY_NAME=Expert Reviewer

# Optional platform defaults
FALLBACK_EMAIL_DOMAIN=example.invalid
MAX_UPLOAD_BYTES=26214400
AUTO_MIGRATE=true
SEED_DEMO_DATA=false
ENABLE_SWAGGER=false
