{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components contexts hooks lib next.config.ts postcss.config.mjs vitest.config.ts vitest.setup.ts eslint.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:install": "playwright install chromium firefox webkit",
    "test:e2e:auth": "node ./scripts/qa/assert-local-stack.mjs && playwright test tests/e2e/setup/auth.setup.ts",
    "test:e2e": "node ./scripts/qa/assert-local-stack.mjs && playwright test",
    "test:e2e:smoke": "node ./scripts/qa/assert-local-stack.mjs && playwright test --grep @smoke",
    "test:e2e:headed": "node ./scripts/qa/assert-local-stack.mjs && playwright test --headed",
    "test:e2e:report": "playwright show-report output/playwright/report",
    "clean": "next clean",
    "backend:run": "dotnet run --project backend/src/OetLearner.Api/OetLearner.Api.csproj",
    "backend:test": "dotnet test backend/OetLearner.sln",
    "backend:build": "dotnet build backend/OetLearner.sln",
    "backend:watch": "dotnet watch --project backend/src/OetLearner.Api/OetLearner.Api.csproj run",
    "backend:smoke": "dotnet run --no-build --project backend/src/OetLearner.Api/OetLearner.Api.csproj"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@hookform/resolvers": "^5.2.1",
    "@microsoft/signalr": "^10.0.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@tabler/icons-react": "^3.41.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.15",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.72.0",
    "react-select": "^5.10.2",
    "recharts": "^3.8.0",
    "sass": "^1.98.0",
    "tailwind-merge": "^3.3.1",
    "wavesurfer.js": "^7.12.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "jsdom": "^29.0.1",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  }
}
