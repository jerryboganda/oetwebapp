# Production environment template.
# Copy to .env.production on the VPS and replace every placeholder before deploy.

# Public URLs and routing
APP_URL=https://app.oetwithdrhesham.co.uk
NEXT_PUBLIC_API_BASE_URL=https://api.oetwithdrhesham.co.uk
PUBLIC_API_BASE_URL=https://api.oetwithdrhesham.co.uk
CHECKOUT_BASE_URL=https://app.oetwithdrhesham.co.uk/billing
CORS_ALLOWED_ORIGINS=https://app.oetwithdrhesham.co.uk
API_ALLOWED_HOSTS=api.oetwithdrhesham.co.uk

# Shared Docker network used by Nginx Proxy Manager
NPM_PROXY_NETWORK=npm_proxy
# Stable blue/green router image. Use an immutable nginx-compatible digest and
# mirror this value in the protected GitHub production environment variable
# ROUTER_IMAGE so release evidence records the exact router image.
ROUTER_IMAGE=nginx@sha256:replace-with-immutable-router-image-digest
HOST_WEB_PORT=3003
HOST_API_PORT=5001

# PostgreSQL
POSTGRES_DB=oet_learner
POSTGRES_USER=oet_learner
POSTGRES_PASSWORD=replace-with-strong-database-password

# Backend first-party auth
AUTH__USEDEVELOPMENTAUTH=false
AUTHTOKENS__ISSUER=https://api.oetwithdrhesham.co.uk
AUTHTOKENS__AUDIENCE=oet-learner-production
AUTHTOKENS__ACCESSTOKENSIGNINGKEY=replace-with-64-character-random-access-token-key
AUTHTOKENS__REFRESHTOKENSIGNINGKEY=replace-with-64-character-random-refresh-token-key
AUTHTOKENS__ACCESSTOKENLIFETIME=00:15:00
AUTHTOKENS__REFRESHTOKENLIFETIME=30.00:00:00
AUTHTOKENS__OTPLIFETIME=00:10:00
AUTHTOKENS__AUTHENTICATORISSUER=OET With Dr Hesham

# Transactional email
BREVO__ENABLED=true
BREVO__APIKEY=replace-with-brevo-api-key
BREVO__BASEURL=https://api.brevo.com/v3
BREVO__FROMEMAIL=no-reply@oetwithdrhesham.co.uk
BREVO__FROMNAME=OET Learner
BREVO__EMAILVERIFICATIONTEMPLATEID=1
BREVO__PASSWORDRESETTEMPLATEID=2
BREVO__WEBHOOKSECRET=replace-with-brevo-webhook-secret
SMTP__ENABLED=true
SMTP__HOST=smtp-relay.brevo.com
SMTP__PORT=587
SMTP__USERNAME=replace-with-brevo-smtp-login
SMTP__PASSWORD=replace-with-brevo-smtp-key
SMTP__ENABLESSL=true
SMTP__FROMEMAIL=no-reply@oetwithdrhesham.co.uk
SMTP__FROMNAME=OET Learner

# Billing
BILLING__ALLOWSANDBOXFALLBACKS=false
BILLING__STRIPE__SECRETKEY=sk_live_replace-with-stripe-secret
BILLING__STRIPE__SUCCESSURL=https://app.oetwithdrhesham.co.uk/billing/success
BILLING__STRIPE__CANCELURL=https://app.oetwithdrhesham.co.uk/billing
BILLING__STRIPE__WEBHOOKSECRET=whsec_replace-with-webhook-secret

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://replace-with-public-key@o0.ingest.sentry.io/0
SENTRY_DSN=https://replace-with-private-key@o0.ingest.sentry.io/0

# Grounded AI provider. Stored into the encrypted provider registry at startup.
AI__BASEURL=https://inference.do-ai.run/v1
AI__APIKEY=replace-with-production-ai-provider-key
AI__PROVIDERID=digitalocean-serverless
AI__DEFAULTMODEL=glm-5
AI__DEFAULTMAXTOKENS=4096
AI__DEFAULTTEMPERATURE=0.2

# Server-authoritative speech providers. Production must not resolve to mock.
PRONUNCIATION__PROVIDER=azure
PRONUNCIATION__AZURESPEECHKEY=replace-with-azure-speech-key
PRONUNCIATION__AZURESPEECHREGION=uksouth
CONVERSATION__ENABLED=true
CONVERSATION__ASRPROVIDER=deepgram
CONVERSATION__DEEPGRAMAPIKEY=replace-with-deepgram-api-key
CONVERSATION__TTSPROVIDER=elevenlabs
CONVERSATION__ELEVENLABSAPIKEY=replace-with-elevenlabs-tts-key

# Upload virus scanner. Production must use the clamav sidecar.
UPLOAD_SCANNER__PROVIDER=clamav
UPLOAD_SCANNER__HOST=clamav
UPLOAD_SCANNER__PORT=3310
UPLOAD_SCANNER__FAILCLOSEDONERROR=true

# Password policy
PASSWORDPOLICY__BREACHCHECKENABLED=true

# Database backups. BACKUP_SCHEDULE is a standard UTC cron spec.
BACKUP_SCHEDULE=17 2 * * *
BACKUP_RETENTION_DAYS=14
BACKUP_GPG_PASSPHRASE=replace-with-strong-backup-passphrase
BACKUP_S3_URL=s3://replace-with-offsite-backup-bucket/oet-prod
BACKUP_S3_EXTRA_ARGS=--endpoint-url https://replace-with-s3-compatible-endpoint
BACKUP_ALERT_WEBHOOK=https://replace-with-alert-host.example.com/backup-alert
BACKUP_AWS_ACCESS_KEY_ID=replace-with-backup-access-key
BACKUP_AWS_SECRET_ACCESS_KEY=replace-with-backup-secret-key
BACKUP_AWS_REGION=auto

# Signed release evidence
EVIDENCE_SIGNER_FINGERPRINT=0123456789ABCDEF0123456789ABCDEF01234567

# Production Reading/media smoke fixtures. Use a least-privilege smoke learner
# with only the fixture entitlement needed for this gate and no MFA requirement.
READING_SMOKE_LEARNER_EMAIL=replace-with-reading-smoke-learner-email
READING_SMOKE_LEARNER_PASSWORD=replace-with-reading-smoke-learner-password
READING_SMOKE_DISABLED_PAPER_ID=replace-with-disabled-paper-mode-paper-id
READING_SMOKE_ENABLED_PAPER_ID=replace-with-enabled-paper-mode-paper-id
READING_SMOKE_PROTECTED_MEDIA_ID=replace-with-protected-paper-media-id
READING_SMOKE_ENTITLED_MEDIA_ID=replace-with-entitled-question-paper-media-id

# Platform defaults
FALLBACK_EMAIL_DOMAIN=oetwithdrhesham.co.uk
MAX_UPLOAD_BYTES=26214400
AUTO_MIGRATE=true
SEED_DEMO_DATA=false
ENABLE_SWAGGER=false
GEMINI_API_KEY=replace-with-gemini-api-key

# Electron desktop release hardening
ELECTRON_UPDATES_URL=https://updates.oetwithdrhesham.co.uk/oet-prep
ELECTRON_WINDOWS_PUBLISHER_NAME=replace-with-windows-publisher-name
ELECTRON_CERT_PINS=[{"host":"api.oetwithdrhesham.co.uk","spkiSha256":["replace-with-base64-spki-pin"]},{"host":"updates.oetwithdrhesham.co.uk","spkiSha256":["replace-with-base64-spki-pin"]}]
ELECTRON_ALLOW_BASIC_TEXT_SECRET_STORAGE=false
