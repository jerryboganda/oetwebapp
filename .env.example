# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ASP.NET Core learner backend base URL used by the Next.js frontend.
NEXT_PUBLIC_API_BASE_URL="http://localhost:5198"

# Native app store URLs used by the Capacitor forced-update flow.
# Android has a code fallback for com.oetprep.learner; set both explicitly in production.
NEXT_PUBLIC_ANDROID_PLAY_STORE_URL="https://play.google.com/store/apps/details?id=com.oetprep.learner"
NEXT_PUBLIC_IOS_APP_STORE_URL=""

# ─────────────────────────────────────────────────────────────────────────────
# AI provider (OpenAI-compatible). The .NET backend reads these as ASP.NET
# Core configuration via the AI__ prefix. The launcher (OET-Launch.ps1)
# forwards any AI__* key found in .env.local into the backend process.
# Pick ONE provider block.
#
# ─── DigitalOcean Serverless Inference (default — GLM-5) ─────────────────────
# AI__ProviderId=digitalocean-serverless
# AI__BaseUrl=https://inference.do-ai.run/v1
# AI__ApiKey=sk-do-...
# AI__DefaultModel=glm-5
# AI__ReasoningEffort=
#
# ─── Cloudflare AI Gateway (frontier + Workers AI unified catalog) ───────────
# OpenCode's built-in Cloudflare AI Gateway provider reads CLOUDFLARE_API_TOKEN.
# OpenCode's built-in Cloudflare Workers AI provider reads CLOUDFLARE_API_KEY.
# The backend/smoke script can use CF_AIG_TOKEN as an alias for the gateway
# token. Never commit real token values; keep them in .env.local or Windows env.
# CLOUDFLARE_ACCOUNT_ID=68970844047393a63eb6338799ff40f8
# CLOUDFLARE_GATEWAY_ID=opencode
# CLOUDFLARE_API_TOKEN=cfut_...
# CLOUDFLARE_API_KEY=<workers-ai-api-token>
# CF_AIG_TOKEN=cfut_...
# AI__ProviderId=cloudflare-ai-gateway
# AI__BaseUrl=https://gateway.ai.cloudflare.com/v1/68970844047393a63eb6338799ff40f8/opencode/compat
# AI__ApiKey=cfut_...
# AI__DefaultModel=anthropic/claude-opus-4.7
# AI__DefaultMaxTokens=32768
# AI__DefaultTemperature=0.2
#
# ─── NVIDIA NIM (https://build.nvidia.com) ───────────────────────────────────
# AI__ProviderId=nvidia-nim
# AI__BaseUrl=https://integrate.api.nvidia.com/v1
# AI__ApiKey=nvapi-...
# AI__DefaultModel=minimaxai/minimax-m2.7
# AI__ReasoningEffort=
# AI__DefaultMaxTokens=16384
# AI__DefaultTemperature=1
# ─────────────────────────────────────────────────────────────────────────────

# ═════════════════════════════════════════════════════════════════════════════
#                          Speaking Module
# ═════════════════════════════════════════════════════════════════════════════
# Full reference: docs/env/speaking.md
#
# ── LiveKit Cloud (live tutor rooms + egress recording) ──────────────────────
# LIVEKIT__PROVIDER=livekit_cloud           # livekit_cloud | disabled (stub)
# LIVEKIT__APIKEY=<your-livekit-api-key>
# LIVEKIT__APISECRET=<your-livekit-api-secret>
# LIVEKIT__WSSURL=wss://<your-project>.livekit.cloud
# LIVEKIT__WEBHOOKSIGNINGSECRET=<random-hmac-secret>
# LIVEKIT__EGRESSBUCKET=oet-livekit-egress
# LIVEKIT__DEFAULTMAXDURATIONSECONDS=1800
# LIVEKIT__EGRESSENABLED=true
#
# ── Anthropic (default Speaking AI provider — Claude Sonnet 4.6 + Haiku 4.5) ─
# Feature routes wired: speaking.score.v2, speaking.patient.turn.v1, card.draft.v1
# ANTHROPIC__APIKEY=<your-anthropic-api-key>
#
# ── OpenAI (fallback + OpenAI-compatible providers) ──────────────────────────
# OPENAI__APIKEY=<your-openai-api-key>
# OPENAI__APIBASE=https://api.openai.com/v1          # override for OpenAI-compatible vendors
#
# ── ElevenLabs (AI patient TTS default) ──────────────────────────────────────
# ELEVENLABS__APIKEY=<your-elevenlabs-api-key>
#
# ── Whisper / ASR (transcribe Speaking sessions) ─────────────────────────────
# WHISPER__APIKEY=<openai-or-whisper-compatible-key>  # often reuses OPENAI__APIKEY
#
# ── AWS S3 (LiveKit egress destination + recording archive) ──────────────────
# AWS__ACCESSKEYID=<your-aws-access-key-id>
# AWS__SECRETACCESSKEY=<your-aws-secret-access-key>
# AWS__REGION=eu-west-2
# AWS__BUCKET=oet-speaking-recordings
#
# ── Speaking compliance (consent versioning + retention windows) ─────────────
# SpeakingCompliance__CurrentConsentVersion=recording.v1
# SpeakingCompliance__CurrentLiveVideoConsentVersion=live_video_with_tutor.v1
# SpeakingCompliance__RetentionDaysDefault=90
# SpeakingCompliance__RetentionDaysWhenTutorReviewed=365
# SpeakingCompliance__AuditLogRetentionDays=2555
#
# ── Feature flags ────────────────────────────────────────────────────────────
# Features__SpeakingV2=false                 # gates the full v2 module rollout
# ═════════════════════════════════════════════════════════════════════════════
