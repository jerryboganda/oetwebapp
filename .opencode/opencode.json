{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent"],
  "provider": {
    "cloudflare-ai-gateway": {
      "models": {
        "anthropic/claude-opus-4.7": {
          "name": "Claude Opus 4.7 (Anthropic, via Cloudflare)",
          "limit": { "context": 1000000, "output": 32768 }
        },
        "anthropic/claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6 (Anthropic, via Cloudflare)",
          "limit": { "context": 1000000, "output": 32768 }
        },
        "openai/gpt-5.5-pro": {
          "name": "GPT-5.5 Pro (OpenAI, via Cloudflare)",
          "limit": { "context": 1000000, "output": 32768 }
        },
        "openai/gpt-5.5": {
          "name": "GPT-5.5 (OpenAI, via Cloudflare)",
          "limit": { "context": 1000000, "output": 32768 }
        },
        "moonshotai/kimi-k2.6": {
          "name": "Kimi K2.6 (Moonshot AI, via Cloudflare)",
          "limit": { "context": 262144, "output": 32768 }
        }
      }
    },
    "cloudflare-workers-ai": {
      "models": {
        "@cf/meta/llama-3.3-70b-instruct-fp8-fast": {
          "name": "Llama 3.3 70B Fast (Cloudflare Workers AI)",
          "limit": { "context": 128000, "output": 8192 }
        },
        "@cf/moonshotai/kimi-k2.5": {
          "name": "Kimi K2.5 (Cloudflare Workers AI)",
          "limit": { "context": 262144, "output": 16384 }
        }
      }
    },
    "digitalocean": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DigitalOcean Serverless Inference",
      "options": {
        "baseURL": "https://inference.do-ai.run/v1",
        "apiKey": "{env:DO_INFERENCE_API_KEY}"
      },
      "models": {
        "kimi-k2.5": {
          "name": "Kimi K2.5 (Moonshot, via DO)",
          "limit": { "context": 256000, "output": 16384 }
        },
        "minimax-m2.5": {
          "name": "MiniMax M2.5 (thinking, via DO)",
          "limit": { "context": 200000, "output": 128000 }
        },
        "glm-5": {
          "name": "GLM 5 (Zhipu, via DO)",
          "limit": { "context": 200000, "output": 16384 }
        }
      }
    }
  }
}
