{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OET with Dr Hesham",
  "version": "0.5.1",
  "identifier": "com.oetwithdrhesham.desktop",
  "build": {
    "frontendDist": "splash"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://app.oetwithdrhesham.co.uk https://api.oetwithdrhesham.co.uk; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["oet-with-dr-hesham"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDMjNEMTg4OEM0MkQ2MkYKUldRdjFrS01pTkVqN0xTVVZnMzJHbm5STnk4eUFHaDIwOWNlQUhpdldPQ3h0SG9meWhrWXVJMHIK",
      "endpoints": ["https://github.com/jerryboganda/oetwebapp/releases/latest/download/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg"],
    "resources": {
      "desktop-runtime-config.json": "desktop-runtime-config.json"
    },
    "icon": [
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements.plist"
    }
  }
}
