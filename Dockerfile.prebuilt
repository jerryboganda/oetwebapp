FROM node:20-alpine AS runner
WORKDIR /app

RUN addgroup -g 10001 -S nodejs \
    && adduser -S nextjs -u 10001

ENV NODE_ENV=production \
    PORT=3000 \
    HOSTNAME=0.0.0.0 \
    NEXT_TELEMETRY_DISABLED=1

COPY .next/standalone ./
COPY .next/static ./.next/static
COPY public ./public
# next-intl message bundles + locale resolver live outside the traced
# standalone output (loaded via dynamic import at request time). Copy them
# explicitly so server-rendered pages resolve translations.
COPY messages ./messages
COPY i18n.ts ./i18n.ts

RUN mkdir -p /app/.next/cache \
    && chown -R nextjs:nodejs /app/.next /app/public

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=5 \
  CMD wget -qO- http://127.0.0.1:3000/api/health >/dev/null || exit 1

USER nextjs

CMD ["node", "server.js"]
