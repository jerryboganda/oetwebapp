{
  "docker.defaultContext": "default",
  "docker.environment": {
    "COMPOSE_PROJECT_NAME": "oet-local"
  },
  "chat.useAgentsMdFile": true,
  "chat.includeApplyingInstructions": true,
  "chat.includeReferencedInstructions": true,
  "chat.useCustomizationsInParentRepositories": true,
  "chat.useNestedAgentsMdFiles": true,
  "chat.agentFilesLocations": {
    ".github/agents": true,
    "~/.copilot/agents": true
  },
  "chat.instructionsFilesLocations": {
    ".github/instructions": true,
    "~/.copilot/instructions": true
  },
  "chat.promptFilesLocations": {
    ".github/prompts": true
  },
  "chat.promptFilesRecommendations": true,
  "chat.subagents.allowInvocationsFromSubagents": true,
  "chat.autopilot.enabled": true,
  "chat.agent.maxRequests": 300,
  "chat.mcp.autoStart": true,

  // Disable heavy language servers — Copilot agents don't need them
  "csharp.suppressDotnetInstallWarning": true,
  "dotnet.server.useOmnisharp": false,
  "omnisharp.enableRoslynAnalyzers": false,
  "python.analysis.diagnosticMode": "openFilesOnly",
  "eslint.run": "onSave",
  "typescript.tsserver.maxTsServerMemory": 1024,
  "diffEditor.maxComputationTime": 0
}
