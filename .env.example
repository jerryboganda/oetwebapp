# Local host development template. Copy to .env.local and fill values as needed.

APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5198
PUBLIC_API_BASE_URL=http://localhost:5198
API_PROXY_TARGET_URL=http://127.0.0.1:5198
GEMINI_API_KEY=

POSTGRES_DB=oet_local
POSTGRES_USER=oet_local
POSTGRES_PASSWORD=replace-with-local-password
DATABASE_URL=Host=localhost;Port=5432;Database=oet_local;Username=oet_local;Password=replace-with-local-password

AUTH__USEDEVELOPMENTAUTH=true
AUTHTOKENS__ISSUER=oet-local
AUTHTOKENS__AUDIENCE=oet-local
AUTHTOKENS__ACCESSTOKENSIGNINGKEY=replace-with-64-character-local-access-key
AUTHTOKENS__REFRESHTOKENSIGNINGKEY=replace-with-64-character-local-refresh-key
AUTHTOKENS__ACCESSTOKENLIFETIME=00:15:00
AUTHTOKENS__REFRESHTOKENLIFETIME=30.00:00:00
AUTHTOKENS__OTPLIFETIME=00:10:00
AUTHTOKENS__AUTHENTICATORISSUER=OET Local

AI__PROVIDERID=mock
AI__BASEURL=
AI__APIKEY=
AI__DEFAULTMODEL=mock
AI__DEFAULTMAXTOKENS=2048
AI__DEFAULTTEMPERATURE=0.2

PRONUNCIATION__PROVIDER=mock
CONVERSATION__ENABLED=true
CONVERSATION__ASRPROVIDER=mock
CONVERSATION__TTSPROVIDER=mock
UPLOAD_SCANNER__PROVIDER=disabled
MAX_UPLOAD_BYTES=1073741824
