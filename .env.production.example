# Frontend public URLs
APP_URL=https://app.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
PUBLIC_API_BASE_URL=https://api.example.com
CHECKOUT_BASE_URL=https://app.example.com/billing/checkout
CORS_ALLOWED_ORIGINS=https://app.example.com

# Electron desktop release hardening
ELECTRON_UPDATES_URL=https://updates.example.com/oet-prep
ELECTRON_WINDOWS_PUBLISHER_NAME=Example Company (Pvt) Ltd
ELECTRON_CERT_PINS=[{"host":"api.example.com","spkiSha256":["replace-with-base64-spki-pin"]},{"host":"updates.example.com","spkiSha256":["replace-with-base64-spki-pin"]}]
# Only use this override for disposable local Linux builds without a secure keyring.
ELECTRON_ALLOW_BASIC_TEXT_SECRET_STORAGE=false

# Shared Docker network used by Nginx Proxy Manager
NPM_PROXY_NETWORK=npm_proxy
HOST_WEB_PORT=3003
HOST_API_PORT=5001

# Next.js server-side integrations
GEMINI_API_KEY=replace-me

# PostgreSQL
POSTGRES_DB=oet_learner
POSTGRES_USER=oet_learner
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Backend first-party auth
AUTH__USEDEVELOPMENTAUTH=false
AUTHTOKENS__ISSUER=https://api.example.com
AUTHTOKENS__AUDIENCE=oet-learner-web
AUTHTOKENS__ACCESSTOKENSIGNINGKEY=replace-with-at-least-32-characters-of-random-secret
AUTHTOKENS__REFRESHTOKENSIGNINGKEY=replace-with-a-different-32-character-secret
AUTHTOKENS__ACCESSTOKENLIFETIME=00:15:00
AUTHTOKENS__REFRESHTOKENLIFETIME=30.00:00:00
AUTHTOKENS__OTPLIFETIME=00:10:00
AUTHTOKENS__AUTHENTICATORISSUER=OET Prep

# Optional Brevo API mode for transactional templates.
# Leave BREVO__ENABLED=false when using the Brevo SMTP relay below.
BREVO__ENABLED=false
BREVO__APIKEY=
BREVO__BASEURL=https://api.brevo.com/v3
BREVO__FROMEMAIL=no-reply@example.com
BREVO__FROMNAME=OET Prep
BREVO__EMAILVERIFICATIONTEMPLATEID=
BREVO__PASSWORDRESETTEMPLATEID=
BREVO__WEBHOOKSECRET=

# Optional platform defaults
FALLBACK_EMAIL_DOMAIN=example.invalid
MAX_UPLOAD_BYTES=26214400
AUTO_MIGRATE=true
SEED_DEMO_DATA=false
ENABLE_SWAGGER=false

# Brevo SMTP relay for production email delivery
SMTP__ENABLED=true
SMTP__HOST=smtp-relay.brevo.com
SMTP__PORT=587
SMTP__USERNAME=replace-with-brevo-smtp-login
SMTP__PASSWORD=replace-with-brevo-smtp-key
SMTP__ENABLESSL=true
SMTP__FROMEMAIL=no-reply@example.com
SMTP__FROMNAME=OET Prep
