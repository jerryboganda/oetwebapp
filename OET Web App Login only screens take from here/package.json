{
  "name": "oet-auth-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "dev": "set NODE_OPTIONS=--max-old-space-size=4096 && next dev --turbo",
    "dev:turbopack": "set NODE_OPTIONS=--max-old-space-size=4096 && next dev --turbo",
    "build": "next build --turbopack",
    "build:turbopack": "next build --turbopack --no-lint",
    "start": "next start",
    "lint": "eslint src next.config.ts eslint.config.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tabler/icons-react": "^3.26.0",
    "country-flag-icons": "^1.5.14",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "react-select": "^5.10.1",
    "sass": "^1.83.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^20",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.0",
    "prettier": "^3.4.2",
    "typescript": "^5"
  }
}
