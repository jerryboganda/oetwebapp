map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

map $http_x_forwarded_proto $public_forwarded_proto {
    default $http_x_forwarded_proto;
    '' $scheme;
}

server {
    listen 8080;
    server_name _;

    # Allow large admin asset uploads (chunked, 8 MB/part; full audio up to ~150 MB).
    client_max_body_size 200m;

    location / {
        resolver 127.0.0.11 ipv6=off valid=10s;
        set $api_upstream http://learner-api-${ACTIVE_SLOT}:8080;

        proxy_pass $api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $public_forwarded_proto;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
