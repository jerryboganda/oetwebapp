{
  "name": "oet-prep",
  "version": "0.1.0",
  "private": true,
  "description": "OET Prep desktop shell",
  "author": "OET Prep",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "mobile:dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "mobile:build": "npm run build && cap sync",
    "mobile:sync": "cap sync",
    "mobile:copy": "cap copy",
    "mobile:run:android": "cap run android",
    "mobile:run:ios": "cap run ios",
    "mobile:open:android": "cap open android",
    "mobile:open:ios": "cap open ios",
    "desktop:dev": "node ./scripts/electron-dev.cjs",
    "desktop:dist": "node ./scripts/desktop-dist.cjs",
    "desktop:electron": "electron .",
    "lint": "eslint app components contexts hooks lib next.config.ts postcss.config.mjs vitest.config.ts vitest.setup.ts eslint.config.mjs",
    "check:encoding": "node ./scripts/check-mojibake.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:install": "playwright install chromium firefox webkit",
    "test:e2e:auth": "node ./scripts/qa/assert-local-stack.mjs && playwright test tests/e2e/setup/auth.setup.ts",
    "test:e2e": "node ./scripts/qa/run-playwright-matrix.mjs full",
    "test:e2e:smoke": "node ./scripts/qa/run-playwright-matrix.mjs smoke",
    "test:e2e:desktop": "node ./scripts/qa/assert-local-stack.mjs && playwright test -c playwright.desktop.config.ts",
    "test:e2e:desktop:packaged": "playwright test -c playwright.desktop.config.ts tests/e2e/desktop/electron-packaged-smoke.spec.ts",
    "test:e2e:prod-privileged": "playwright test -c playwright.prod-privileged.config.ts",
    "test:e2e:headed": "node ./scripts/qa/assert-local-stack.mjs && playwright test --headed",
    "test:e2e:report": "playwright show-report output/playwright/report",
    "clean": "next clean",
    "backend:run": "dotnet run --project backend/src/OetLearner.Api/OetLearner.Api.csproj",
    "backend:test": "dotnet test backend/OetLearner.sln",
    "backend:build": "dotnet build backend/OetLearner.sln",
    "backend:watch": "dotnet watch --project backend/src/OetLearner.Api/OetLearner.Api.csproj run",
    "backend:smoke": "dotnet run --no-build --project backend/src/OetLearner.Api/OetLearner.Api.csproj",
    "ai:gateway:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/test-cf-gateway.ps1",
    "ai:workers:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/test-cf-workers-ai.ps1",
    "unused:scan": "ts-prune -p tsconfig.json | node ./scripts/ts-prune-filter.mjs",
    "repomix:pack": "npx -y repomix@latest",
    "repomix:pack:compress": "npx -y repomix@latest --compress",
    "repomix:hook:install": "powershell -ExecutionPolicy Bypass -File ./scripts/repomix/install-hook.ps1"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^7.2.0",
    "@capacitor/app": "^6.0.3",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/camera": "^6.0.5",
    "@capacitor/core": "^6.2.1",
    "@capacitor/device": "^6.0.3",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/network": "^6.0.4",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/push-notifications": "^6.0.5",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@google/genai": "^1.17.0",
    "@hookform/resolvers": "^5.2.1",
    "@microsoft/signalr": "^10.0.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@sentry/nextjs": "^10.50.0",
    "@tabler/icons-react": "^3.41.0",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-query-devtools": "^5.100.1",
    "@tanstack/react-virtual": "^3.13.24",
    "autoprefixer": "^10.4.21",
    "capacitor-secure-storage-plugin": "^0.10.0",
    "capacitor-voice-recorder": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.15",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.5.15",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.72.0",
    "react-select": "^5.10.2",
    "recharts": "^3.8.0",
    "sass": "^1.98.0",
    "tailwind-merge": "^3.3.1",
    "wavesurfer.js": "^7.12.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.oetprep.desktop",
    "productName": "OET Prep",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static"
      },
      {
        "from": "public",
        "to": "standalone/public"
      },
      {
        "from": "desktop-backend-runtime",
        "to": "backend-runtime"
      }
    ],
    "win": {
      "signAndEditExecutable": true,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@electron/fuses": "^2.1.1",
    "@modelcontextprotocol/server-sequential-thinking": "2025.12.18",
    "@playwright/mcp": "0.0.69",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "jsdom": "^29.0.1",
    "tailwindcss": "4.1.11",
    "ts-prune": "0.10.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  }
}
