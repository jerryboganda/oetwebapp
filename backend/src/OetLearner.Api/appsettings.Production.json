{
  "Bootstrap": {
    "AutoMigrate": true,
    "SeedDemoData": false
  },
  "Proxy": {
    "TrustForwardHeaders": true,
    "EnforceHttps": true
  },
  "Features": {
    "EnableSwagger": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  }
}
