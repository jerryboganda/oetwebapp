# =============================================================================
# .env.docker-local — Docker Desktop full-stack environment
# =============================================================================
# Copy this file to `.env.docker-local` and fill in any optional service keys.
# Usage:
#   docker compose -f docker-compose.local.yml --env-file .env.docker-local up --build -d
#
# Most values below are safe dev defaults. Only fill in API keys for services
# you actually want to test locally (AI, Stripe, Brevo, Pronunciation, etc.).
# =============================================================================

# --- Database ---
POSTGRES_DB=oet_learner_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Auth ---
AUTH_USE_DEVELOPMENT_AUTH=true
AUTH_ALLOW_DEVELOPMENT_AUTH_IN_PRODUCTION=false

# --- URLs ---
PUBLIC_API_BASE_URL=http://localhost:8080
APP_URL=http://localhost:3000
CHECKOUT_BASE_URL=http://localhost:3000/billing/checkout

# --- Bootstrap ---
AUTO_MIGRATE=true
SEED_DEMO_DATA=true
BOOTSTRAP_EXPERT_EMAIL=expert@example.com
BOOTSTRAP_EXPERT_PASSWORD=Expert123!
BOOTSTRAP_EXPERT_DISPLAY_NAME=Demo Expert

# --- Auth Tokens (use any random strings for local dev) ---
AUTHTOKENS__ISSUER=oet-learner-local
AUTHTOKENS__AUDIENCE=oet-learner-local
AUTHTOKENS__ACCESSTOKENSIGNINGKEY=local-dev-access-token-signing-key-min-32-chars!!
AUTHTOKENS__REFRESHTOKENSIGNINGKEY=local-dev-refresh-token-signing-key-min-32-chars!!
AUTHTOKENS__ACCESSTOKENLIFETIME=01:00:00
AUTHTOKENS__REFRESHTOKENLIFETIME=30.00:00:00
AUTHTOKENS__OTPLIFETIME=00:05:00
AUTHTOKENS__AUTHENTICATORISSUER=OET-Local

# --- Billing (Stripe) — leave empty to use sandbox fallbacks ---
BILLING__STRIPE__SECRETKEY=
BILLING__STRIPE__SUCCESSURL=http://localhost:3000/billing/success
BILLING__STRIPE__CANCELURL=http://localhost:3000/billing/cancel
BILLING__STRIPE__WEBHOOKSECRET=
BILLING__ALLOWSANDBOXFALLBACKS=true

# --- Email: Brevo (disabled by default for local) ---
BREVO__ENABLED=false
BREVO__APIKEY=
BREVO__BASEURL=https://api.brevo.com/v3
BREVO__FROMEMAIL=noreply@localhost
BREVO__FROMNAME=OET Local
BREVO__EMAILVERIFICATIONTEMPLATEID=0
BREVO__PASSWORDRESETTEMPLATEID=0
BREVO__WEBHOOKSECRET=

# --- Email: SMTP (disabled by default for local) ---
SMTP__ENABLED=false
SMTP__HOST=
SMTP__PORT=587
SMTP__USERNAME=
SMTP__PASSWORD=
SMTP__ENABLESSL=true
SMTP__FROMEMAIL=noreply@localhost
SMTP__FROMNAME=OET Local

# --- AI (leave empty to disable AI features) ---
AI__APIKEY=
AI__BASEURL=
AI__PROVIDERID=
AI__DEFAULTMODEL=
AI__DEFAULTTEMPERATURE=0.7
AI__DEFAULTMAXTOKENS=4096
AI__REASONINGEFFORT=medium

# --- Pronunciation (leave empty to use Mock provider) ---
PRONUNCIATION__PROVIDER=Mock
PRONUNCIATION__AZURESPEECHKEY=
PRONUNCIATION__AZURESPEECHREGION=

# --- Conversation (disabled by default for local) ---
CONVERSATION__ENABLED=false
CONVERSATION__ASRPROVIDER=Mock
CONVERSATION__DEEPGRAMAPIKEY=
CONVERSATION__TTSPROVIDER=off
CONVERSATION__ELEVENLABSAPIKEY=
CONVERSATION__REALTIMEASRPROVIDER=Mock
CONVERSATION__CHATTTSBASEURL=
CONVERSATION__CHATTTSAPIKEY=
CONVERSATION__CHATTTSDEFAULTVOICE=

# --- Upload limits ---
MAX_UPLOAD_BYTES=52428800

# --- Listening Sample Seeder ---
# Imports 3 real OET Listening sample papers on startup (idempotent).
# Requires the "Project Real Content/" folder mounted into the container.
SEED__LISTENINGSAMPLES__ENABLED=true
SEED__LISTENINGSAMPLES__SOURCEROOT=/app/real-content/Listening ( IMPORTANT NOTE =  Same for All Professions )
