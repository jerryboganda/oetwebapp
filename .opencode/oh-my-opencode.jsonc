{
  // ===========================================================================
  //  Oh My OpenAgent — OET Prep Platform routing
  // ===========================================================================
  //
  //  Locked routing per user mandate:
  //    Anthropic (Opus 4.7, Sonnet 4.6) → github-copilot subscription ONLY
  //    OpenAI    (GPT 5.5, 5.5-pro)     → opencode (Zen) subscription ONLY
  //    Cheap/fast tier                  → digitalocean/kimi-k2.5 (custom provider)
  //
  //  Provider definitions live in .opencode/opencode.json (the github-copilot
  //  and opencode providers are auto-detected by OpenCode from the user's
  //  subscriptions; digitalocean is a custom OpenAI-compatible provider that
  //  reads its key from DO_INFERENCE_API_KEY in .env.local).
  // ===========================================================================

  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // === 1. Sisyphus orchestrator: FULLY ENABLED ============================
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": true,
    "planner_enabled": true,
    "replace_plan": true
  },

  // === 2. Sisyphus Tasks: cross-session state =============================
  "sisyphus": {
    "tasks": {
      "enabled": true,
      "storage_path": ".sisyphus/tasks",
      "claude_code_compat": false
    }
  },

  // === 3. Agent routing ===================================================
  "agents": {
    // -- Main orchestrator: Opus 4.7 via Copilot --
    "sisyphus": {
      "model": "github-copilot/claude-opus-4.7",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.6",
        "opencode/gpt-5.5",
        "digitalocean/kimi-k2.5"
      ]
    },

    // -- Deep autonomous worker: GPT-native via Zen --
    "hephaestus": {
      "model": "opencode/gpt-5.5",
      "reasoningEffort": "high",
      "fallback_models": [
        { "model": "opencode/gpt-5.5-pro", "reasoningEffort": "high" },
        { "model": "opencode/gpt-5.4-pro", "reasoningEffort": "high" }
      ]
    },

    // -- Strategic planner (dual-prompt: Claude↔GPT auto-switch) --
    "prometheus": {
      "model": "github-copilot/claude-opus-4.7",
      "fallback_models": [
        { "model": "opencode/gpt-5.5-pro", "reasoningEffort": "high" },
        { "model": "opencode/gpt-5.5",     "reasoningEffort": "high" },
        "github-copilot/claude-sonnet-4.6"
      ],
      "prompt_append": "This is the OET Prep Platform (Next.js 15 + ASP.NET Core 10 + Capacitor + Electron). ALWAYS consult AGENTS.md at project root before planning — it encodes MISSION-CRITICAL invariants for OET Scoring, Rulebooks, AI Gateway, Content Upload, Reading Authoring, Grammar/Pronunciation/Conversation modules, and the Statement of Results card. Violate any of those invariants and the plan is wrong by definition. Leverage deep & quick agents heavily, always in parallel."
    },

    // -- Plan reviewer (Claude-family) --
    "metis": {
      "model": "github-copilot/claude-opus-4.7",
      "fallback_models": [
        { "model": "opencode/gpt-5.5-pro", "reasoningEffort": "high" },
        "github-copilot/claude-sonnet-4.6"
      ]
    },

    // -- Architecture / hard debugging (GPT-native, high-reasoning) --
    "oracle": {
      "model": "opencode/gpt-5.5-pro",
      "reasoningEffort": "high",
      "fallback_models": [
        { "model": "opencode/gpt-5.5", "reasoningEffort": "high" },
        "github-copilot/claude-opus-4.7"
      ]
    },

    // -- Verification / review --
    "momus": {
      "model": "opencode/gpt-5.5-pro",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        { "model": "opencode/gpt-5.5", "reasoningEffort": "high" },
        "github-copilot/claude-opus-4.7"
      ]
    },

    // -- Todo orchestrator (Sonnet via Copilot) --
    "atlas": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        { "model": "opencode/gpt-5.5", "reasoningEffort": "medium" },
        "digitalocean/kimi-k2.5"
      ]
    },

    // -- Speed-critical: Librarian (docs/code search) --
    "librarian": {
      "model": "digitalocean/kimi-k2.5",
      "fallback_models": [
        { "model": "opencode/gpt-5.5", "reasoningEffort": "minimal" },
        "github-copilot/claude-sonnet-4.6"
      ]
    },

    // -- Speed-critical: Explore (fast grep) --
    "explore": {
      "model": "digitalocean/kimi-k2.5",
      "fallback_models": [
        { "model": "opencode/gpt-5.5", "reasoningEffort": "minimal" },
        "github-copilot/claude-sonnet-4.6"
      ]
    },

    // -- Vision / multimodal --
    "multimodal-looker": {
      "model": "opencode/gpt-5.5",
      "reasoningEffort": "medium",
      "fallback_models": [
        "github-copilot/claude-opus-4.7"
      ]
    },

    // -- Junior Sisyphus (background chores) --
    "sisyphus-junior": {
      "model": "digitalocean/kimi-k2.5",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.6",
        { "model": "opencode/gpt-5.5", "reasoningEffort": "minimal" }
      ]
    }
  },

  // === 4. Categories — task() delegation routing ==========================
  "categories": {
    "quick": {
      "model": "digitalocean/kimi-k2.5",
      "description": "Trivial edits, typos, single-file renames",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.6"
      ]
    },
    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.6",
      "description": "General low-effort tasks",
      "fallback_models": [
        "digitalocean/kimi-k2.5"
      ]
    },
    "unspecified-high": {
      "model": "github-copilot/claude-opus-4.7",
      "description": "General high-effort tasks",
      "fallback_models": [
        "opencode/gpt-5.5",
        "github-copilot/claude-sonnet-4.6"
      ]
    },
    "deep": {
      "model": "opencode/gpt-5.5",
      "reasoningEffort": "high",
      "description": "Autonomous research + execution",
      "fallback_models": [
        { "model": "opencode/gpt-5.5-pro", "reasoningEffort": "high" },
        "github-copilot/claude-opus-4.7"
      ]
    },
    "ultrabrain": {
      "model": "opencode/gpt-5.5-pro",
      "reasoningEffort": "xhigh",
      "description": "Hard logic, architecture, OET scoring invariants, AI-gateway policy",
      "fallback_models": [
        { "model": "opencode/gpt-5.5", "reasoningEffort": "high" },
        "github-copilot/claude-opus-4.7"
      ]
    },
    "visual-engineering": {
      "model": "github-copilot/claude-sonnet-4.6",
      "description": "Tailwind 4 / Next.js 15 / React 19 / motion v12 UI work — follow DESIGN.md tokens and motion-system skill; never restyle OET Statement of Results card.",
      "fallback_models": [
        "github-copilot/claude-opus-4.7",
        "digitalocean/kimi-k2.5"
      ]
    },
    "writing": {
      "model": "github-copilot/claude-sonnet-4.6",
      "description": "Docs, prose, release notes, AGENTS.md updates",
      "fallback_models": [
        "digitalocean/kimi-k2.5"
      ]
    },
    "artistry": {
      "model": "github-copilot/claude-opus-4.7",
      "description": "Creative / unconventional approaches",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.6",
        "digitalocean/kimi-k2.5"
      ]
    }
  },

  // === 5. Background task concurrency =====================================
  "background_task": {
    "defaultConcurrency": 6,
    "staleTimeoutMs": 240000,
    "providerConcurrency": {
      "github-copilot": 8,
      "opencode": 8,
      "digitalocean": 10
    },
    "modelConcurrency": {
      "github-copilot/claude-opus-4.7":   3,
      "github-copilot/claude-sonnet-4.6": 5,
      "opencode/gpt-5.5-pro":             3,
      "opencode/gpt-5.5":                 5,
      "opencode/gpt-5.4-pro":             3,
      "digitalocean/kimi-k2.5":           8
    }
  },

  // === 6. MCPs ============================================================
  "disabled_mcps": ["websearch"],

  // === 7. Hashline edit tool ==============================================
  "hashline_edit": true,

  // === 8. LSP — TypeScript ================================================
  "lsp": {
    "typescript-language-server": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".mts", ".cts", ".js", ".jsx", ".mjs", ".cjs"],
      "priority": 10,
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=4096"
      }
    }
  },

  // === 9. Runtime fallback — never stall on rate limits ===================
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 408, 425, 429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 5,
    "cooldown_seconds": 45,
    "timeout_seconds": 60,
    "notify_on_fallback": true
  },

  // === 10. Skills =========================================================
  "skills": {
    "sources": [
      { "path": "./.agents/skills", "recursive": true },
      { "path": "./.opencode/skills", "recursive": true }
    ]
  },

  // === 11. Git Master =====================================================
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false
  },

  // === 12. Notifications ==================================================
  "notification": { "force_enable": true },

  // === 13. Tmux — OFF (Windows) ===========================================
  "tmux": { "enabled": false },

  // === 14. Model capabilities — refresh off (custom DO IDs) ===============
  "model_capabilities": {
    "enabled": true,
    "auto_refresh_on_start": false
  },

  // === 15. Experimental ===================================================
  "experimental": {
    "truncate_all_tool_outputs": false,
    "aggressive_truncation": true,
    "auto_resume": true,
    "disable_omo_env": false,
    "task_system": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": { "enabled": true, "turns": 4 },
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "lsp_rename",
        "lsp_find_references",
        "session_read",
        "session_write",
        "session_search"
      ],
      "strategies": {
        "deduplication":    { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false },
        "purge_errors":     { "enabled": true, "turns": 5 }
      }
    }
  },

  // === 16. Hooks & commands — keep almost everything enabled ==============
  "disabled_hooks": ["rules-injector"],
  "disabled_commands": ["init-deep"],

  "disabled_agents": [],
  "disabled_skills": []
}
