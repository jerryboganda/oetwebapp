    "@microsoft/signalr": "^10.0.0",
    "@next/env": "^16.2.6",
    "@paypal/react-paypal-js": "^10.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.50.0",
    "@tabler/icons-react": "^3.41.0",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-query-devtools": "^5.100.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@tiptap/core": "^2.8.0",
    "@tiptap/pm": "^2.8.0",
    "@tiptap/react": "^2.8.0",
    "@tiptap/starter-kit": "^2.8.0",
    "@zoom/meetingsdk": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "capacitor-voice-recorder": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-flag-icons": "^1.6.15",
    "diff-match-patch": "^1.0.5",
    "driver.js": "1.4.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^16.2.6",
    "@opentelemetry/api": "^1.9.0",
    "next-intl": "^3.20.0",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "6.0.227",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.72.0",
    "react-select": "^5.10.2",
    "recharts": "^3.8.0",
    "sass": "^1.98.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tus-js-client": "^4.3.1",
    "vaul": "^1.1.2",
    "wavesurfer.js": "^7.12.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "@parcel/watcher",
      "@sentry/cli",
      "@tailwindcss/oxide",
      "@zoom/meetingsdk",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
