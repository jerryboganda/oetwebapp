# ============================================================================
# Staging environment example
# Copy to .env.staging and fill with non-production values.
# Never commit .env.staging — it is git-ignored.
#
# Variables marked REQUIRED must be set before the stack will start.
# Variables marked OPTIONAL have safe defaults and can be left as-is.
# See docs/STAGING-LOCAL-GITHUB-PLAN.md for the full setup checklist.
# ============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=oet_staging
POSTGRES_USER=oet_staging
# REQUIRED: Set a non-production database password (any strong random string).
POSTGRES_PASSWORD=replace-with-non-prod-password

# --- Public URLs and routing --------------------------------------------------
# REQUIRED: Set these to match the staging DNS/proxy names.
API_ALLOWED_HOSTS=api-staging.oetwithdrhesham.co.uk;staging-api.oetwithdrhesham.co.uk
PUBLIC_API_BASE_URL=https://api-staging.oetwithdrhesham.co.uk
NEXT_PUBLIC_API_BASE_URL=https://api-staging.oetwithdrhesham.co.uk
APP_URL=https://staging.oetwithdrhesham.co.uk
CHECKOUT_BASE_URL=https://staging.oetwithdrhesham.co.uk
CORS_ALLOWED_ORIGINS=https://staging.oetwithdrhesham.co.uk

# --- Authentication -----------------------------------------------------------
# REQUIRED: Use false in staging; set true only for local dev without real auth.
AUTH__USEDEVELOPMENTAUTH=false
AUTHTOKENS__ISSUER=oet-staging
AUTHTOKENS__AUDIENCE=oet-staging
# REQUIRED: Generate two separate 64-char random strings (non-production).
AUTHTOKENS__ACCESSTOKENSIGNINGKEY=replace-with-64-char-non-prod-secret
AUTHTOKENS__REFRESHTOKENSIGNINGKEY=replace-with-64-char-non-prod-secret
# OPTIONAL: Token lifetimes — defaults match production.
AUTHTOKENS__ACCESSTOKENLIFETIME=00:15:00
AUTHTOKENS__REFRESHTOKENLIFETIME=30.00:00:00
AUTHTOKENS__OTPLIFETIME=00:10:00
AUTHTOKENS__AUTHENTICATORISSUER=OET Staging

# --- Transactional email (Brevo / SMTP) --------------------------------------
# Disabled by default in staging. Enable and fill in when email testing is needed.
BREVO__ENABLED=false
# OPTIONAL: Fill these in only when BREVO__ENABLED=true.
BREVO__APIKEY=
BREVO__BASEURL=https://api.brevo.com/v3
BREVO__FROMEMAIL=staging@example.invalid
BREVO__FROMNAME=OET Staging
BREVO__EMAILVERIFICATIONTEMPLATEID=1
BREVO__PASSWORDRESETTEMPLATEID=2
BREVO__WEBHOOKSECRET=

SMTP__ENABLED=false
# OPTIONAL: Fill these in only when SMTP__ENABLED=true.
SMTP__HOST=
SMTP__PORT=587
SMTP__USERNAME=
SMTP__PASSWORD=
SMTP__ENABLESSL=true
SMTP__FROMEMAIL=staging@example.invalid
SMTP__FROMNAME=OET Staging

# --- Billing (Stripe) --------------------------------------------------------
# OPTIONAL: Sandbox fallbacks are enabled so Stripe keys are not strictly required.
BILLING__ALLOWSANDBOXFALLBACKS=true
# REQUIRED when testing Stripe: use sk_test_ key, never sk_live_.
BILLING__STRIPE__SECRETKEY=sk_test_replace
BILLING__STRIPE__WEBHOOKSECRET=whsec_replace
BILLING__STRIPE__SUCCESSURL=https://staging.oetwithdrhesham.co.uk/billing/success
BILLING__STRIPE__CANCELURL=https://staging.oetwithdrhesham.co.uk/billing/cancel

# --- Sentry (error tracking) -------------------------------------------------
# OPTIONAL: Leave blank to disable Sentry in staging.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# --- Password policy ----------------------------------------------------------
# OPTIONAL: Enable breach-check in staging to mirror production behaviour.
PASSWORDPOLICY__BREACHCHECKENABLED=false

# --- Platform defaults --------------------------------------------------------
AUTO_MIGRATE=true
SEED_DEMO_DATA=true
ENABLE_SWAGGER=true
MAX_UPLOAD_BYTES=26214400
FALLBACK_EMAIL_DOMAIN=staging.example.invalid

# --- Upload virus scanner (ClamAV sidecar) -----------------------------------
UPLOAD_SCANNER__PROVIDER=clamav
UPLOAD_SCANNER__HOST=clamav
UPLOAD_SCANNER__PORT=3310
UPLOAD_SCANNER__FAILCLOSEDONERROR=true

# --- AI provider --------------------------------------------------------------
# OPTIONAL: Defaults to mock. Set a real provider only when testing AI features.
AI__ProviderId=mock
AI__BaseUrl=
AI__ApiKey=
AI__DefaultModel=mock
AI__ReasoningEffort=low
AI__DefaultMaxTokens=2048
AI__DefaultTemperature=0.2

# --- Docker networking --------------------------------------------------------
# OPTIONAL: Must match the external network created by Nginx Proxy Manager.
NPM_PROXY_NETWORK=npm_proxy

# --- Web frontend -------------------------------------------------------------
# OPTIONAL: Gemini API key for AI features in the web frontend.
GEMINI_API_KEY=
